{
  "description": "Shared lifecycle guardrails for Codex.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.codex/hooks/compact-reorient.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.codex/hooks/git-stash-guard.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
